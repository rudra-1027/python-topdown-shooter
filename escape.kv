#:import Window kivy.core.window.Window
#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp

# ── GLOBAL SCALE FACTOR ──────────────────────────────────────────────────────
# Tune this one number to make everything bigger or smaller.
# 0.70 = compact mobile  |  0.80 = normal mobile  |  1.0 = PC original size
#:set S 0.70

<MainMenu>:

    Image:
        source: 'gameAsset/game_menu/menu.png'
        allow_stretch: True
        keep_ratio: False
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

    Widget:
        size_hint: 1, 1
        canvas:
            Color:
                rgba: 0, 0, 0, 0.60
            Rectangle:
                pos: self.pos
                size: self.size

    # ── LEFT PANEL ──
    BoxLayout:
        orientation: 'vertical'
        size_hint: None, 1
        width: min(dp(340) * S, Window.width * 0.88)
        pos_hint: {'x': 0, 'y': 0}
        spacing: dp(8) * S
        padding: [dp(28) * S, dp(36) * S, dp(28) * S, dp(28) * S]

        canvas.before:
            Color:
                rgba: 0.04, 0.04, 0.08, 0.93
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 0.91, 0.75, 0.29, 0.4
            Rectangle:
                pos: self.right - dp(2), self.y
                size: dp(2), self.height

        Label:
            text: 'LAST TEEN STANDING'
            font_size: sp(28) * S
            bold: True
            color: 0.91, 0.9, 0.96, 1
            size_hint_y: None
            height: dp(60) * S
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        Label:
            text: 'MAIN MENU'
            font_size: sp(10) * S
            color: 0.42, 0.39, 0.54, 1
            size_hint_y: None
            height: dp(20) * S
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        Widget:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.07
                Rectangle:
                    pos: self.pos
                    size: self.size

        Widget:
            size_hint_y: None
            height: dp(6) * S

        # ── STATS ROW ──
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(64) * S
            spacing: dp(8) * S

            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.03
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6) * S]
                Label:
                    text: 'BEST SCORE'
                    font_size: sp(9) * S
                    bold: True
                    color: 0.5, 0.45, 0.65, 1
                    size_hint_y: None
                    height: dp(18) * S
                    halign: 'center'
                    text_size: self.size
                Label:
                    id: best_score_label
                    text: '0'
                    font_size: sp(18) * S
                    bold: True
                    color: 0.91, 0.75, 0.29, 1
                    halign: 'center'
                    text_size: self.size

            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.03
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6) * S]
                Label:
                    text: 'BEST WAVE'
                    font_size: sp(9) * S
                    bold: True
                    color: 0.5, 0.45, 0.65, 1
                    size_hint_y: None
                    height: dp(18) * S
                    halign: 'center'
                    text_size: self.size
                Label:
                    id: best_wave_label
                    text: '0'
                    font_size: sp(18) * S
                    bold: True
                    color: 0.85, 0.8, 1, 1
                    halign: 'center'
                    text_size: self.size

        Widget:
            size_hint_y: None
            height: dp(14) * S

        # ── NEW GAME BUTTON ──
        Button:
            text: 'NEW GAME'
            size_hint_y: None
            height: dp(54) * S
            font_size: sp(14) * S
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.15, 0.12, 0.05, 1
            on_release:
                root.start_new_game()
                app.play_click()
            canvas.before:
                Color:
                    rgba: 0.91, 0.75, 0.29, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8) * S]
                Color:
                    rgba: 1, 1, 1, 0.12
                RoundedRectangle:
                    pos: self.x + dp(4) * S, self.top - dp(10) * S
                    size: self.width - dp(8) * S, dp(8) * S
                    radius: [dp(6) * S]

        # ── CONTINUE BUTTON ──
        Button:
            id: continue_btn
            text: 'CONTINUE FROM WAVE'
            size_hint_y: None
            height: dp(54) * S
            font_size: sp(13) * S
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.88, 0.86, 0.94, 1
            on_release:
                root.continue_game()
                app.play_click()
            canvas.before:
                Color:
                    rgba: 0.12, 0.13, 0.18, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8) * S]
                Color:
                    rgba: 1, 1, 1, 0.06
                Line:
                    rounded_rectangle: self.x, self.y, self.width, self.height, dp(8) * S
                    width: dp(1)

        # ── QUIT BUTTON ──
        Button:
            text: 'QUIT'
            size_hint_y: None
            height: dp(54) * S
            font_size: sp(14) * S
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.90, 0.38, 0.38, 1
            on_release:
                app.play_click()
                app.stop()
            canvas.before:
                Color:
                    rgba: 0.18, 0.07, 0.07, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8) * S]
                Color:
                    rgba: 0.80, 0.22, 0.22, 0.25
                Line:
                    rounded_rectangle: self.x, self.y, self.width, self.height, dp(8) * S
                    width: dp(1)

        Widget:

        Label:
            text: 'v1.0.0'
            font_size: sp(9) * S
            color: 0.25, 0.22, 0.32, 1
            size_hint_y: None
            height: dp(18) * S
            halign: 'left'
            valign: 'middle'
            text_size: self.size

<Game>:

<Ground>:
    size_hint: None, None
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            source: root.source
            pos: self.pos
            size: self.size

<Obstacle>:
    size_hint: None, None
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            source: root.source
            pos: self.pos
            size: self.size

<Player>:
    size_hint: None, None
    size: dp(100), dp(100)
    canvas:
        Rectangle:
            texture: root.texture
            pos: self.pos
            size: self.size

<Enemy>:
    size_hint: None, None
    size: dp(30), dp(30)
    canvas:
        Color:
            rgba: root.color
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

<Effect>:
    size_hint: None, None
    size: dp(100), dp(100)
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

<DamageNumber@Label>:
    size_hint: None, None
    font_size: sp(20) * S
    bold: True
    color: 1, 0.24, 0.24, 1

<Attack>:
    size_hint: None, None
    size: dp(15), dp(15)
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

# ── JOYSTICK ──
<Joystick>:
    size_hint: None, None
    size: dp(150) * S, dp(150) * S
    canvas:
        Color:
            rgba: 0, 0, 0, 0.45
        Ellipse:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0, 1, 0.8, 0.30
        Line:
            ellipse: self.x, self.y, self.width, self.height
            width: dp(2)
        Color:
            rgba: 0, 1, 0.8, 0.10
        Line:
            points: self.center_x - self.width * 0.387, self.center_y, self.center_x + self.width * 0.387, self.center_y
            width: dp(1)
        Color:
            rgba: 0, 1, 0.8, 0.10
        Line:
            points: self.center_x, self.center_y - self.height * 0.387, self.center_x, self.center_y + self.height * 0.387
            width: dp(1)
        Color:
            rgba: 0, 1, 0.8, 0.15
        Ellipse:
            pos: self.center_x - self.width * 0.213, self.center_y - self.height * 0.213
            size: self.width * 0.427, self.height * 0.427
        Color:
            rgba: 0.04, 0.10, 0.14, 0.95
        Ellipse:
            pos: root.knob_x - self.width * 0.173, root.knob_y - self.height * 0.173
            size: self.width * 0.347, self.height * 0.347
        Color:
            rgba: 0, 1, 0.8, 0.90
        Line:
            ellipse: root.knob_x - self.width * 0.173, root.knob_y - self.height * 0.173, self.width * 0.347, self.height * 0.347
            width: dp(1.8)

# ── ATTACK JOYSTICK ──
<AttackJoystick>:
    size_hint: None, None
    size: dp(150) * S, dp(150) * S
    canvas:
        Color:
            rgba: 0, 0, 0, 0.45
        Ellipse:
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 0.24, 0.24, 0.35
        Line:
            ellipse: self.x, self.y, self.width, self.height
            width: dp(2)
        Color:
            rgba: 1, 0.24, 0.24, 0.10
        Line:
            points: self.center_x - self.width * 0.387, self.center_y, self.center_x + self.width * 0.387, self.center_y
            width: dp(1)
        Color:
            rgba: 1, 0.24, 0.24, 0.10
        Line:
            points: self.center_x, self.center_y - self.height * 0.387, self.center_x, self.center_y + self.height * 0.387
            width: dp(1)
        Color:
            rgba: 1, 0.24, 0.24, 0.18
        Ellipse:
            pos: self.center_x - self.width * 0.213, self.center_y - self.height * 0.213
            size: self.width * 0.427, self.height * 0.427
        Color:
            rgba: 0.14, 0.04, 0.04, 0.95
        Ellipse:
            pos: root.knob_x - self.width * 0.173, root.knob_y - self.height * 0.173
            size: self.width * 0.347, self.height * 0.347
        Color:
            rgba: 1, 0.24, 0.24, 0.90
        Line:
            ellipse: root.knob_x - self.width * 0.173, root.knob_y - self.height * 0.173, self.width * 0.347, self.height * 0.347
            width: dp(1.8)

<HealthBar>:
    size_hint: None, None
    size: dp(90) * S, dp(10) * S
    canvas:
        Color:
            rgba: 0.08, 0.08, 0.10, 0.92
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(5) * S]
        Color:
            rgba: 0.3, 0.05, 0.05, 0.8
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(5) * S
            width: dp(1)
        Color:
            rgba: (1, 0.18, 0.18, 1) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.width * min(1, self.health / self.max_health), self.height
            radius: [dp(5) * S]

<PlayerHealthBar>:
    size_hint: None, None
    size: min(dp(260) * S, Window.width * 0.52), dp(80) * S

    canvas.before:
        Color:
            rgba: 0.04, 0.05, 0.06, 0.94
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14) * S]
        Color:
            rgba: 1, 1, 1, 0.07
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(14) * S
            width: dp(1)
        Color:
            rgba: 0.9, 0.21, 0.21, 0.18
        RoundedRectangle:
            pos: self.x + dp(12) * S, self.y + dp(44) * S
            size: dp(28) * S, dp(28) * S
            radius: [dp(8) * S]
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            source: "gameAsset/Characters/player_icon.png"
            pos: self.x + dp(16) * S, self.y + dp(48) * S
            size: dp(20) * S, dp(20) * S
        Color:
            rgba: 0.9, 0.21, 0.21, 0.38
        Line:
            rounded_rectangle: self.x + dp(12) * S, self.y + dp(44) * S, dp(28) * S, dp(28) * S, dp(8) * S
            width: dp(1)
        Color:
            rgba: 1, 1, 1, 0.07
        RoundedRectangle:
            pos: self.x + dp(12) * S, self.y + dp(30) * S
            size: self.width - dp(24) * S, dp(8) * S
            radius: [dp(4) * S]
        Color:
            rgba: (0.9, 0.21, 0.21, 1) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x + dp(12) * S, self.y + dp(30) * S
            size: (0, 0) if self.health <= 0 else ((self.width - dp(24) * S) * max(0, min(1, self.health / self.max_health)), dp(8) * S)
            radius: [dp(4) * S]
        Color:
            rgba: (1, 1, 1, 0.18) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x + dp(18) * S, self.y + dp(34) * S
            size: (0, 0) if self.health <= 0 else (max(0, (self.width - dp(36) * S) * max(0, min(1, self.health / self.max_health))), dp(2) * S)
            radius: [dp(2) * S]
        Color:
            rgba: 1, 1, 1, 0.05
        Rectangle:
            pos: self.x + dp(12) * S, self.y + dp(22) * S
            size: self.width - dp(24) * S, dp(1)

    Label:
        text: "TEEN"
        font_size: sp(11) * S
        bold: True
        color: 1, 1, 1, 0.55
        pos: root.x + dp(48) * S, root.y + dp(44) * S
        size: dp(100) * S, dp(28) * S
        halign: "left"
        valign: "middle"
        text_size: self.size

    Label:
        text: f"{max(0, int(root.health))} / {int(root.max_health)}"
        font_size: sp(13) * S
        bold: True
        color: 1, 1, 1, 1
        pos: root.right - dp(80) * S, root.y + dp(44) * S
        size: dp(68) * S, dp(28) * S
        halign: "right"
        valign: "middle"
        text_size: self.size

    Label:
        id: status_label
        text: root.status_text
        font_size: sp(14) * S
        bold: True
        color: root.status_color
        pos: root.x + dp(24) * S, root.y + dp(4) * S
        size: root.width - dp(36) * S, dp(20) * S
        halign: "left"
        valign: "middle"
        text_size: self.size

<PowerUp>:
    size_hint: None, None
    size: dp(28) * S, dp(28) * S
    canvas:
        Color:
            rgba: root.color[0], root.color[1], root.color[2], 0.28
        Ellipse:
            pos: self.x - dp(5) * S, self.y - dp(5) * S
            size: self.width + dp(10) * S, self.height + dp(10) * S
        Color:
            rgba: root.color
        Ellipse:
            texture: root.texture
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 1, 1, 0.20
        Ellipse:
            pos: self.center_x - dp(8) * S, self.center_y - dp(2) * S
            size: dp(10) * S, dp(6) * S
    Label:
        text: root.symbol
        center: root.center
        font_size: sp(15) * S
        bold: True
        color: 0, 0, 0, 0.9

<Gun>:
    size_hint: None, None
    size: dp(34) * S, dp(12) * S
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas:
        Color:
            rgba: 0.12, 0.15, 0.20, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(3) * S]
        Color:
            rgba: 0.50, 0.62, 0.72, 1
        RoundedRectangle:
            pos: self.center_x, self.center_y - dp(2) * S
            size: dp(14) * S, dp(4) * S
            radius: [dp(2) * S]
        Color:
            rgba: 0, 1, 0.8, 0.85
        Rectangle:
            pos: self.right - dp(3) * S, self.center_y - dp(2) * S
            size: dp(3) * S, dp(4) * S
    canvas.after:
        PopMatrix


<GameUI>:
    ammo_ratio: 1
    size_hint: 1, 1

    # ── PAUSE MENU ──
    FloatLayout:
        id: pause_menu
        opacity: 0
        disabled: True

        Image:
            source: 'gameAsset/game_menu/menu.png'
            allow_stretch: True
            keep_ratio: False
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}

        Widget:
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            canvas:
                Color:
                    rgba: 0, 0, 0, 0.55
                Rectangle:
                    pos: self.pos
                    size: self.size

        BoxLayout:
            orientation: 'vertical'
            size_hint: None, 1
            width: min(dp(320) * S, Window.width * 0.88)
            pos_hint: {'x': 0, 'y': 0}
            spacing: dp(6) * S
            padding: [dp(28) * S, dp(32) * S, dp(28) * S, dp(24) * S]

            canvas.before:
                Color:
                    rgba: 0.04, 0.04, 0.08, 0.93
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.91, 0.75, 0.29, 0.4
                Rectangle:
                    pos: self.right - dp(2), self.y
                    size: dp(2), self.height

            Label:
                text: 'LAST TEEN STANDING'
                font_size: sp(11) * S
                bold: True
                color: 0.91, 0.75, 0.29, 1
                size_hint_y: None
                height: dp(20) * S
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            Label:
                text: 'PAUSED'
                font_size: sp(26) * S
                bold: True
                color: 0.91, 0.9, 0.96, 1
                size_hint_y: None
                height: dp(38) * S
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: 1, 1, 1, 0.07
                    Rectangle:
                        pos: self.pos
                        size: self.size

            Widget:
                size_hint_y: None
                height: dp(8) * S

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(64) * S
                spacing: dp(8) * S

                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.03
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6) * S]
                    Label:
                        text: 'WAVE'
                        font_size: sp(9) * S
                        bold: True
                        color: 0.5, 0.45, 0.65, 1
                        size_hint_y: None
                        height: dp(18) * S
                        halign: 'center'
                        text_size: self.size
                    Label:
                        id: stat_wave
                        text: '1'
                        font_size: sp(20) * S
                        bold: True
                        color: 0.85, 0.8, 1, 1
                        halign: 'center'
                        text_size: self.size

                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.03
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6) * S]
                    Label:
                        text: 'SCORE'
                        font_size: sp(9) * S
                        bold: True
                        color: 0.5, 0.45, 0.65, 1
                        size_hint_y: None
                        height: dp(18) * S
                        halign: 'center'
                        text_size: self.size
                    Label:
                        id: stat_score
                        text: '0'
                        font_size: sp(20) * S
                        bold: True
                        color: 0.85, 0.8, 1, 1
                        halign: 'center'
                        text_size: self.size

            Widget:
                size_hint_y: None
                height: dp(16) * S

            Button:
                text: 'RESUME'
                size_hint_y: None
                height: dp(54) * S
                font_size: sp(14) * S
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.15, 0.12, 0.05, 1
                on_release:
                    root.parent.resume()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.91, 0.75, 0.29, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8) * S]
                    Color:
                        rgba: 1, 1, 1, 0.12
                    RoundedRectangle:
                        pos: self.x + dp(4) * S, self.top - dp(10) * S
                        size: self.width - dp(8) * S, dp(8) * S
                        radius: [dp(6) * S]

            Button:
                text: 'RESTART'
                size_hint_y: None
                height: dp(54) * S
                font_size: sp(14) * S
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.88, 0.86, 0.94, 1
                on_release:
                    root.parent.restart()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.12, 0.13, 0.18, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8) * S]
                    Color:
                        rgba: 1, 1, 1, 0.06
                    Line:
                        rounded_rectangle: self.x, self.y, self.width, self.height, dp(8) * S
                        width: dp(1)

            Button:
                text: 'QUIT TO MENU'
                size_hint_y: None
                height: dp(54) * S
                font_size: sp(14) * S
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.90, 0.38, 0.38, 1
                on_release:
                    root.parent.quit_to_menu()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.18, 0.07, 0.07, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8) * S]
                    Color:
                        rgba: 0.80, 0.22, 0.22, 0.25
                    Line:
                        rounded_rectangle: self.x, self.y, self.width, self.height, dp(8) * S
                        width: dp(1)

            Widget:

            Label:
                text: 'v1.0.0  ·  WAVE IN PROGRESS'
                font_size: sp(9) * S
                color: 0.25, 0.22, 0.32, 1
                size_hint_y: None
                height: dp(18) * S
                halign: 'left'
                valign: 'middle'
                text_size: self.size

    # ── PAUSE BUTTON ──
    Button:
        id: pause_button
        text: "II"
        size_hint: None, None
        size: dp(50) * S, dp(50) * S
        pos_hint: {"right": 0.985, "top": 0.985}
        font_size: sp(16) * S
        bold: True
        background_normal: ""
        background_color: 0,0,0,0
        color: 1,1,1,0.92
        on_release:
            root.parent.pause()
            root.parent.play_click()
        canvas.before:
            Color:
                rgba: 0.12,0.13,0.16,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12) * S]
            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(12) * S
                width: dp(1)

    # ── WEAPON BUTTON ──
    Button:
        id: weapon_button
        text: "W"
        size_hint: None, None
        size: dp(50) * S, dp(50) * S
        pos_hint: {"right": 0.985, "top": 0.89}
        font_size: sp(18) * S
        bold: True
        background_normal: ""
        background_color: 0,0,0,0
        color: 0.92,0.82,0.58,1
        on_release:
            root.parent.weapon_menu.open_menu(list(root.parent.player.guns.keys()), self.center_x, self.center_y)
            root.parent.play_click()
        canvas.before:
            Color:
                rgba: 0.14,0.12,0.09,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12) * S]
            Color:
                rgba: 0.92,0.82,0.58,0.15
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(12) * S
                width: dp(1)

    # ── GUN BAR ──
    GunBar:
        id: gun_ui
        orientation: "horizontal"
        size_hint: None, None
        size: min(dp(320) * S, Window.width * 0.85), dp(64) * S
        spacing: dp(12) * S
        padding: [dp(14) * S, dp(10) * S]
        pos_hint: {"center_x": 0.5, "y": 0.016}
        on_release: root.parent.player.gun.startReload()
        canvas.before:
            Color:
                rgba: 0.10,0.11,0.13,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(14) * S]
            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(14) * S
                width: dp(1)

        BoxLayout:
            size_hint_x: None
            width: dp(40) * S
            padding: [dp(4) * S, dp(4) * S, dp(4) * S, dp(4) * S]
            canvas.before:
                Color:
                    rgba: 1,1,1,0.04
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8) * S]
            Image:
                id: gun_icon
                source: "gameAsset/gun/ak.png"
                size_hint: 1, 1

        BoxLayout:
            orientation: "vertical"
            size_hint_x: None
            width: dp(110) * S
            Label:
                id: gun_text
                text: "ASSAULT"
                font_size: sp(13) * S
                bold: True
                color: 1,1,1,0.96
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                id: ammo_text
                text: "30 / 30"
                font_size: sp(11) * S
                bold: True
                color: 0.82,0.74,0.55,0.85
                halign: "left"
                valign: "middle"
                text_size: self.size

        BoxLayout:
            orientation: "vertical"
            spacing: dp(5) * S
            Widget:
                size_hint_y: None
                height: dp(8) * S
                canvas:
                    Color:
                        rgba: 0.18,0.18,0.20,1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(4) * S]
                    Color:
                        rgba: 0.88,0.77,0.50,1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.width * root.ammo_ratio, self.height
                        radius: [dp(4) * S]
            Label:
                text: "TAP TO RELOAD"
                font_size: sp(9) * S
                bold: True
                color: 1,1,1,0.35
                halign: "center"
                valign: "middle"
                text_size: self.size

    # ── TOP HUD ──
    BoxLayout:
        id: top_hud
        orientation: "horizontal"
        size_hint: None, None
        size: min(dp(320) * S, Window.width * 0.70), dp(58) * S
        spacing: dp(8) * S
        padding: [dp(10) * S, dp(8) * S]
        pos_hint: {"center_x": 0.5, "top": 0.985}
        canvas.before:
            Color:
                rgba: 0.10,0.11,0.13,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12) * S]
            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(12) * S
                width: dp(1)

        BoxLayout:
            orientation: "vertical"
            canvas.before:
                Color:
                    rgba: 1,1,1,0.025
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8) * S]
            Label:
                text: "WAVE"
                font_size: sp(9) * S
                bold: True
                color: 0.82,0.74,0.55,0.75
                size_hint_y: None
                height: dp(14) * S
            Label:
                id: wave_label
                text: "1"
                font_size: sp(21) * S
                bold: True
                color: 0.96,0.96,0.96,1

        Widget:
            size_hint_x: None
            width: dp(1)
            canvas:
                Color:
                    rgba: 1,1,1,0.04
                Rectangle:
                    pos: self.center_x, self.y + dp(10) * S
                    size: dp(1), self.height - dp(20) * S

        BoxLayout:
            orientation: "vertical"
            canvas.before:
                Color:
                    rgba: 1,1,1,0.025
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8) * S]
            Label:
                text: "SCORE"
                font_size: sp(9) * S
                bold: True
                color: 0.82,0.74,0.55,0.75
                size_hint_y: None
                height: dp(14) * S
            Label:
                id: score_label
                text: "0"
                font_size: sp(21) * S
                bold: True
                color: 0.96,0.96,0.96,1


<GunBar@ButtonBehavior+BoxLayout>:


# ════════════════════════════════════════════════════
#  UPGRADE PANEL
# ════════════════════════════════════════════════════
<UpgradePanel>:
    size_hint: 1, 1

    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.72
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: "vertical"
        spacing: 0
        size_hint: None, None
        size: min(dp(600) * S, Window.width * 0.95), min(dp(340) * S, Window.height * 0.55)
        pos_hint: {"center_x": 0.5, "center_y": 0.5}

        canvas.before:
            Color:
                rgba: 0.11, 0.11, 0.12, 0.98
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(18) * S]
            Color:
                rgba: 1, 1, 1, 0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(18) * S
                width: dp(1.2)
            Color:
                rgba: 1, 1, 1, 0.025
            RoundedRectangle:
                pos: self.x + dp(2), self.top - dp(50) * S
                size: self.width - dp(4), dp(48) * S
                radius: [dp(18) * S, dp(18) * S, 0, 0]

        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: dp(80) * S
            spacing: dp(4) * S
            padding: [0, dp(18) * S, 0, 0]

            Label:
                text: "LEVEL UP"
                font_size: sp(28) * S
                bold: True
                color: 0.96, 0.96, 0.96, 1
                halign: "center"
                valign: "middle"
                text_size: self.size

            Label:
                text: "Choose an Upgrade"
                font_size: sp(11) * S
                color: 1, 1, 1, 0.40
                halign: "center"
                valign: "middle"
                text_size: self.size

        Widget:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.05
                Rectangle:
                    pos: self.x + dp(28) * S, self.y
                    size: self.width - dp(56) * S, dp(1)

        BoxLayout:
            id: upgrade_box
            orientation: "horizontal"
            spacing: dp(16) * S
            padding: [dp(18) * S, dp(18) * S, dp(18) * S, dp(18) * S]
