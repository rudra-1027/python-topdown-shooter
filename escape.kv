#:import Window kivy.core.window.Window
#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp

<MainMenu>:

    # ── BACKGROUND IMAGE ──
    Image:
        source: 'gameAsset/game_menu/menu.png'
        allow_stretch: True
        keep_ratio: False
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

    # ── DARK OVERLAY ──
    Widget:
        size_hint: 1, 1
        canvas:
            Color:
                rgba: 0, 0, 0, 0.60
            Rectangle:
                pos: self.pos
                size: self.size

    # ── LEFT PANEL ──
    BoxLayout:
        orientation: 'vertical'
        size_hint: None, 1
        width: min(dp(340), Window.width * 0.88)
        pos_hint: {'x': 0, 'y': 0}
        spacing: dp(8)
        padding: [dp(28), dp(36), dp(28), dp(28)]

        canvas.before:
            Color:
                rgba: 0.04, 0.04, 0.08, 0.93
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 0.91, 0.75, 0.29, 0.4
            Rectangle:
                pos: self.right - dp(2), self.y
                size: dp(2), self.height
            Color:
                rgba: 0.91, 0.75, 0.29, 1

        # ── TITLE ──
        Label:
            text: 'LAST TEEN STANDING'
            font_size: sp(22)
            bold: True
            color: 0.91, 0.9, 0.96, 1
            size_hint_y: None
            height: dp(60)
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        Label:
            text: 'MAIN MENU'
            font_size: sp(10)
            color: 0.42, 0.39, 0.54, 1
            size_hint_y: None
            height: dp(20)
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        # ── DIVIDER ──
        Widget:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.07
                Rectangle:
                    pos: self.pos
                    size: self.size

        Widget:
            size_hint_y: None
            height: dp(6)

        # ── STATS ROW ──
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(64)
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.03
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
                Label:
                    text: 'BEST SCORE'
                    font_size: sp(9)
                    bold: True
                    color: 0.5, 0.45, 0.65, 1
                    size_hint_y: None
                    height: dp(18)
                    halign: 'center'
                    text_size: self.size
                Label:
                    id: best_score_label
                    text: '0'
                    font_size: sp(18)
                    bold: True
                    color: 0.91, 0.75, 0.29, 1
                    halign: 'center'
                    text_size: self.size

            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.03
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
                Label:
                    text: 'BEST WAVE'
                    font_size: sp(9)
                    bold: True
                    color: 0.5, 0.45, 0.65, 1
                    size_hint_y: None
                    height: dp(18)
                    halign: 'center'
                    text_size: self.size
                Label:
                    id: best_wave_label
                    text: '0'
                    font_size: sp(18)
                    bold: True
                    color: 0.85, 0.8, 1, 1
                    halign: 'center'
                    text_size: self.size

        Widget:
            size_hint_y: None
            height: dp(14)

        # ── NEW GAME BUTTON (gold) ──
        Button:
            text: 'NEW GAME'
            size_hint_y: None
            height: dp(54)
            font_size: sp(14)
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.15, 0.12, 0.05, 1
            on_release:
                root.start_new_game()
                app.play_click()
            canvas.before:
                Color:
                    rgba: 0.91, 0.75, 0.29, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
                Color:
                    rgba: 1, 1, 1, 0.12
                RoundedRectangle:
                    pos: self.x + dp(4), self.top - dp(10)
                    size: self.width - dp(8), dp(8)
                    radius: [dp(6)]

        # ── CONTINUE BUTTON ──
        Button:
            id: continue_btn
            text: 'CONTINUE FROM WAVE'
            size_hint_y: None
            height: dp(54)
            font_size: sp(13)
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.88, 0.86, 0.94, 1
            on_release:
                root.continue_game()
                app.play_click()
            canvas.before:
                Color:
                    rgba: 0.12, 0.13, 0.18, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
                Color:
                    rgba: 1, 1, 1, 0.06
                Line:
                    rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
                    width: dp(1)
                Color:
                    rgba: 0.91, 0.75, 0.29, 0.7

        # ── QUIT BUTTON ──
        Button:
            text: 'QUIT'
            size_hint_y: None
            height: dp(54)
            font_size: sp(14)
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.90, 0.38, 0.38, 1
            on_release:
                app.play_click()
                app.stop()
            canvas.before:
                Color:
                    rgba: 0.18, 0.07, 0.07, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
                Color:
                    rgba: 0.80, 0.22, 0.22, 0.25
                Line:
                    rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
                    width: dp(1)
                Color:
                    rgba: 0.85, 0.25, 0.25, 0.8

        Widget:

        Label:
            text: 'v1.0.0'
            font_size: sp(9)
            color: 0.25, 0.22, 0.32, 1
            size_hint_y: None
            height: dp(18)
            halign: 'left'
            valign: 'middle'
            text_size: self.size

<Game>:

<Ground>:
    size_hint: None, None
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            source: root.source
            pos: self.pos
            size: self.size

<Obstacle>:
    size_hint: None, None
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            source: root.source
            pos: self.pos
            size: self.size

<Player>:
    size_hint: None, None
    size: dp(100), dp(100)
    canvas:
        Rectangle:
            texture: root.texture
            pos: self.pos
            size: self.size

<Enemy>:
    size_hint: None, None
    size: dp(30), dp(30)
    canvas:
        Color:
            rgba: root.color
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

<Effect>:
    size_hint: None, None
    size: dp(100), dp(100)
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

<DamageNumber@Label>:
    size_hint: None, None
    font_size: sp(20)
    bold: True
    color: 1, 0.24, 0.24, 1

<Attack>:
    size_hint: None, None
    size: dp(15), dp(15)
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

# ── JOYSTICK (movement) ──────────────────────────────
<Joystick>:
    size_hint: None, None
    size: dp(150), dp(150)
    canvas:
        Color:
            rgba: 0, 0, 0, 0.45
        Ellipse:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0, 1, 0.8, 0.30
        Line:
            ellipse: self.x, self.y, self.width, self.height
            width: dp(2)
        Color:
            rgba: 0, 1, 0.8, 0.10
        Line:
            points: self.center_x - dp(58), self.center_y, self.center_x + dp(58), self.center_y
            width: dp(1)
        Color:
            rgba: 0, 1, 0.8, 0.10
        Line:
            points: self.center_x, self.center_y - dp(58), self.center_x, self.center_y + dp(58)
            width: dp(1)
        Color:
            rgba: 0, 1, 0.8, 0.15
        Ellipse:
            pos: self.center_x - dp(32), self.center_y - dp(32)
            size: dp(64), dp(64)
        Color:
            rgba: 0.04, 0.10, 0.14, 0.95
        Ellipse:
            pos: root.knob_x - dp(26), root.knob_y - dp(26)
            size: dp(52), dp(52)
        Color:
            rgba: 0, 1, 0.8, 0.90
        Line:
            ellipse: root.knob_x - dp(26), root.knob_y - dp(26), dp(52), dp(52)
            width: dp(1.8)

# ── ATTACK JOYSTICK (fire) ───────────────────────────
<AttackJoystick>:
    size_hint: None, None
    size: dp(150), dp(150)
    canvas:
        Color:
            rgba: 0, 0, 0, 0.45
        Ellipse:
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 0.24, 0.24, 0.35
        Line:
            ellipse: self.x, self.y, self.width, self.height
            width: dp(2)
        Color:
            rgba: 1, 0.24, 0.24, 0.10
        Line:
            points: self.center_x - dp(58), self.center_y, self.center_x + dp(58), self.center_y
            width: dp(1)
        Color:
            rgba: 1, 0.24, 0.24, 0.10
        Line:
            points: self.center_x, self.center_y - dp(58), self.center_x, self.center_y + dp(58)
            width: dp(1)
        Color:
            rgba: 1, 0.24, 0.24, 0.18
        Ellipse:
            pos: self.center_x - dp(32), self.center_y - dp(32)
            size: dp(64), dp(64)
        Color:
            rgba: 0.14, 0.04, 0.04, 0.95
        Ellipse:
            pos: root.knob_x - dp(26), root.knob_y - dp(26)
            size: dp(52), dp(52)
        Color:
            rgba: 1, 0.24, 0.24, 0.90
        Line:
            ellipse: root.knob_x - dp(26), root.knob_y - dp(26), dp(52), dp(52)
            width: dp(1.8)

<HealthBar>:
    size_hint: None, None
    size: dp(90), dp(10)
    canvas:
        Color:
            rgba: 0.08, 0.08, 0.10, 0.92
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(5)]
        Color:
            rgba: 0.3, 0.05, 0.05, 0.8
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(5)
            width: dp(1)
        Color:
            rgba: (1, 0.18, 0.18, 1) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.width * min(1, self.health / self.max_health), self.height
            radius: [dp(5)]

<PlayerHealthBar>:
    size_hint: None, None
    size: min(dp(260), Window.width * 0.55), dp(80)

    canvas.before:
        Color:
            rgba: 0.04, 0.05, 0.06, 0.94
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14)]
        Color:
            rgba: 1, 1, 1, 0.07
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(14)
            width: dp(1)

        Color:
            rgba: 0.9, 0.21, 0.21, 0.18
        RoundedRectangle:
            pos: self.x + dp(12), self.y + dp(44)
            size: dp(28), dp(28)
            radius: [dp(8)]
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            source: "gameAsset/Characters/player_icon.png"
            pos: self.x + dp(16), self.y + dp(48)
            size: dp(20), dp(20)

        Color:
            rgba: 0.9, 0.21, 0.21, 0.38
        Line:
            rounded_rectangle: self.x + dp(12), self.y + dp(44), dp(28), dp(28), dp(8)
            width: dp(1)

        Color:
            rgba: 1, 1, 1, 0.07
        RoundedRectangle:
            pos: self.x + dp(12), self.y + dp(30)
            size: self.width - dp(24), dp(8)
            radius: [dp(4)]

        Color:
            rgba: (0.9, 0.21, 0.21, 1) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x + dp(12), self.y + dp(30)
            size: (0, 0) if self.health <= 0 else ((self.width - dp(24)) * max(0, min(1, self.health / self.max_health)), dp(8))
            radius: [dp(4)]

        Color:
            rgba: (1, 1, 1, 0.18) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x + dp(18), self.y + dp(34)
            size: (0, 0) if self.health <= 0 else (max(0, (self.width - dp(36)) * max(0, min(1, self.health / self.max_health))), dp(2))
            radius: [dp(2)]

        Color:
            rgba: 1, 1, 1, 0.05
        Rectangle:
            pos: self.x + dp(12), self.y + dp(22)
            size: self.width - dp(24), dp(1)

    Label:
        text: "TEEN"
        font_size: sp(11)
        bold: True
        color: 1, 1, 1, 0.55
        pos: root.x + dp(48), root.y + dp(44)
        size: dp(100), dp(28)
        halign: "left"
        valign: "middle"
        text_size: self.size

    Label:
        text: f"{max(0, int(root.health))} / {int(root.max_health)}"
        font_size: sp(13)
        bold: True
        color: 1, 1, 1, 1
        pos: root.right - dp(80), root.y + dp(44)
        size: dp(68), dp(28)
        halign: "right"
        valign: "middle"
        text_size: self.size

    Label:
        id: status_label
        text: root.status_text
        font_size: sp(14)
        bold: True
        color: root.status_color
        pos: root.x + dp(24), root.y + dp(4)
        size: root.width - dp(36), dp(20)
        halign: "left"
        valign: "middle"
        text_size: self.size

<PowerUp>:
    size_hint: None, None
    size: dp(28), dp(28)
    canvas:
        Color:
            rgba: root.color[0], root.color[1], root.color[2], 0.28
        Ellipse:
            pos: self.x - dp(5), self.y - dp(5)
            size: self.width + dp(10), self.height + dp(10)
        Color:
            rgba: root.color
        Ellipse:
            texture: root.texture
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 1, 1, 0.20
        Ellipse:
            pos: self.center_x - dp(8), self.center_y - dp(2)
            size: dp(10), dp(6)
    Label:
        text: root.symbol
        center: root.center
        font_size: sp(15)
        bold: True
        color: 0, 0, 0, 0.9

<Gun>:
    size_hint: None, None
    size: dp(34), dp(12)
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas:
        Color:
            rgba: 0.12, 0.15, 0.20, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(3)]
        Color:
            rgba: 0.50, 0.62, 0.72, 1
        RoundedRectangle:
            pos: self.center_x, self.center_y - dp(2)
            size: dp(14), dp(4)
            radius: [dp(2)]
        Color:
            rgba: 0, 1, 0.8, 0.85
        Rectangle:
            pos: self.right - dp(3), self.center_y - dp(2)
            size: dp(3), dp(4)
    canvas.after:
        PopMatrix


<GameUI>:
    ammo_ratio: 1
    size_hint: 1, 1

    # ─────────────────────────────────────────────
    # PAUSE MENU
    # ─────────────────────────────────────────────
    FloatLayout:
        id: pause_menu
        opacity: 0
        disabled: True

        Image:
            source: 'gameAsset/game_menu/menu.png'
            allow_stretch: True
            keep_ratio: False
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}

        Widget:
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            canvas:
                Color:
                    rgba: 0, 0, 0, 0.55
                Rectangle:
                    pos: self.pos
                    size: self.size

        # ── LEFT PANEL ──
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, 1
            width: min(dp(320), Window.width * 0.88)
            pos_hint: {'x': 0, 'y': 0}
            spacing: dp(6)
            padding: [dp(28), dp(32), dp(28), dp(24)]

            canvas.before:
                Color:
                    rgba: 0.04, 0.04, 0.08, 0.93
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.91, 0.75, 0.29, 0.4
                Rectangle:
                    pos: self.right - dp(2), self.y
                    size: dp(2), self.height
                Color:
                    rgba: 0.91, 0.75, 0.29, 1

            Label:
                text: 'LAST TEEN STANDING'
                font_size: sp(11)
                bold: True
                color: 0.91, 0.75, 0.29, 1
                size_hint_y: None
                height: dp(20)
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            Label:
                text: 'PAUSED'
                font_size: sp(26)
                bold: True
                color: 0.91, 0.9, 0.96, 1
                size_hint_y: None
                height: dp(38)
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: 1, 1, 1, 0.07
                    Rectangle:
                        pos: self.pos
                        size: self.size

            Widget:
                size_hint_y: None
                height: dp(8)

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(64)
                spacing: dp(8)

                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.03
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
                    Label:
                        text: 'WAVE'
                        font_size: sp(9)
                        bold: True
                        color: 0.5, 0.45, 0.65, 1
                        size_hint_y: None
                        height: dp(18)
                        halign: 'center'
                        text_size: self.size
                    Label:
                        id: stat_wave
                        text: '1'
                        font_size: sp(20)
                        bold: True
                        color: 0.85, 0.8, 1, 1
                        halign: 'center'
                        text_size: self.size

                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.03
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
                    Label:
                        text: 'SCORE'
                        font_size: sp(9)
                        bold: True
                        color: 0.5, 0.45, 0.65, 1
                        size_hint_y: None
                        height: dp(18)
                        halign: 'center'
                        text_size: self.size
                    Label:
                        id: stat_score
                        text: '0'
                        font_size: sp(20)
                        bold: True
                        color: 0.85, 0.8, 1, 1
                        halign: 'center'
                        text_size: self.size

            Widget:
                size_hint_y: None
                height: dp(16)

            Button:
                text: 'RESUME'
                size_hint_y: None
                height: dp(54)
                font_size: sp(14)
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.15, 0.12, 0.05, 1
                on_release:
                    root.parent.resume()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.91, 0.75, 0.29, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                    Color:
                        rgba: 1, 1, 1, 0.12
                    RoundedRectangle:
                        pos: self.x + dp(4), self.top - dp(10)
                        size: self.width - dp(8), dp(8)
                        radius: [dp(6)]

            Button:
                text: 'RESTART'
                size_hint_y: None
                height: dp(54)
                font_size: sp(14)
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.88, 0.86, 0.94, 1
                on_release:
                    root.parent.restart()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.12, 0.13, 0.18, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                    Color:
                        rgba: 1, 1, 1, 0.06
                    Line:
                        rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
                        width: dp(1)
                    Color:
                        rgba: 0.91, 0.75, 0.29, 0.7

            Button:
                text: 'QUIT TO MENU'
                size_hint_y: None
                height: dp(54)
                font_size: sp(14)
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.90, 0.38, 0.38, 1
                on_release:
                    root.parent.quit_to_menu()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.18, 0.07, 0.07, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                    Color:
                        rgba: 0.80, 0.22, 0.22, 0.25
                    Line:
                        rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
                        width: dp(1)
                    Color:
                        rgba: 0.85, 0.25, 0.25, 0.8

            Widget:

            Label:
                text: 'v1.0.0  ·  WAVE IN PROGRESS'
                font_size: sp(9)
                color: 0.25, 0.22, 0.32, 1
                size_hint_y: None
                height: dp(18)
                halign: 'left'
                valign: 'middle'
                text_size: self.size

    # ─────────────────────────────────────────────
    # PAUSE BUTTON
    # ─────────────────────────────────────────────
    Button:
        id: pause_button
        text: "II"
        size_hint: None, None
        size: dp(50), dp(50)
        pos_hint: {"right": 0.985, "top": 0.985}
        font_size: sp(16)
        bold: True
        background_normal: ""
        background_color: 0,0,0,0
        color: 1,1,1,0.92
        on_release:
            root.parent.pause()
            root.parent.play_click()
        canvas.before:
            Color:
                rgba: 0.12,0.13,0.16,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12)]
            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(12)
                width: dp(1)

    # ─────────────────────────────────────────────
    # WEAPON BUTTON
    # ─────────────────────────────────────────────
    Button:
        id: weapon_button
        text: "W"
        size_hint: None, None
        size: dp(50), dp(50)
        pos_hint: {"right": 0.985, "top": 0.89}
        font_size: sp(18)
        bold: True
        background_normal: ""
        background_color: 0,0,0,0
        color: 0.92,0.82,0.58,1
        on_release:
            root.parent.weapon_menu.open_menu(list(root.parent.player.guns.keys()), self.center_x, self.center_y)
            root.parent.play_click()
        canvas.before:
            Color:
                rgba: 0.14,0.12,0.09,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12)]
            Color:
                rgba: 0.92,0.82,0.58,0.15
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(12)
                width: dp(1)

    # ─────────────────────────────────────────────
    # GUN BAR
    # ─────────────────────────────────────────────
    GunBar:
        id: gun_ui
        orientation: "horizontal"
        size_hint: None, None
        size: min(dp(320), Window.width * 0.88), dp(64)
        spacing: dp(12)
        padding: [dp(14), dp(10)]
        pos_hint: {"center_x": 0.5, "y": 0.016}
        on_release: root.parent.player.gun.startReload()
        canvas.before:
            Color:
                rgba: 0.10,0.11,0.13,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(14)]
            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(14)
                width: dp(1)

        BoxLayout:
            size_hint_x: None
            width: dp(40)
            padding: [dp(4), dp(4), dp(4), dp(4)]
            canvas.before:
                Color:
                    rgba: 1,1,1,0.04
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
            Image:
                id: gun_icon
                source: "gameAsset/gun/ak.png"
                size_hint: 1, 1

        BoxLayout:
            orientation: "vertical"
            size_hint_x: None
            width: dp(110)
            Label:
                id: gun_text
                text: "ASSAULT"
                font_size: sp(13)
                bold: True
                color: 1,1,1,0.96
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                id: ammo_text
                text: "30 / 30"
                font_size: sp(11)
                bold: True
                color: 0.82,0.74,0.55,0.85
                halign: "left"
                valign: "middle"
                text_size: self.size

        BoxLayout:
            orientation: "vertical"
            spacing: dp(5)
            Widget:
                size_hint_y: None
                height: dp(8)
                canvas:
                    Color:
                        rgba: 0.18,0.18,0.20,1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(4)]
                    Color:
                        rgba: 0.88,0.77,0.50,1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.width * root.ammo_ratio, self.height
                        radius: [dp(4)]
            Label:
                text: "TAP TO RELOAD"
                font_size: sp(9)
                bold: True
                color: 1,1,1,0.35
                halign: "center"
                valign: "middle"
                text_size: self.size

    # ─────────────────────────────────────────────
    # TOP HUD
    # ─────────────────────────────────────────────
    BoxLayout:
        id: top_hud
        orientation: "horizontal"
        size_hint: None, None
        size: min(dp(320), Window.width * 0.72), dp(58)
        spacing: dp(8)
        padding: [dp(10), dp(8)]
        pos_hint: {"center_x": 0.5, "top": 0.985}
        canvas.before:
            Color:
                rgba: 0.10,0.11,0.13,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12)]
            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(12)
                width: dp(1)

        BoxLayout:
            orientation: "vertical"
            canvas.before:
                Color:
                    rgba: 1,1,1,0.025
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
            Label:
                text: "WAVE"
                font_size: sp(9)
                bold: True
                color: 0.82,0.74,0.55,0.75
                size_hint_y: None
                height: dp(14)
            Label:
                id: wave_label
                text: "1"
                font_size: sp(21)
                bold: True
                color: 0.96,0.96,0.96,1

        Widget:
            size_hint_x: None
            width: dp(1)
            canvas:
                Color:
                    rgba: 1,1,1,0.04
                Rectangle:
                    pos: self.center_x, self.y + dp(10)
                    size: dp(1), self.height - dp(20)

        BoxLayout:
            orientation: "vertical"
            canvas.before:
                Color:
                    rgba: 1,1,1,0.025
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
            Label:
                text: "SCORE"
                font_size: sp(9)
                bold: True
                color: 0.82,0.74,0.55,0.75
                size_hint_y: None
                height: dp(14)
            Label:
                id: score_label
                text: "0"
                font_size: sp(21)
                bold: True
                color: 0.96,0.96,0.96,1


<GunBar@ButtonBehavior+BoxLayout>:


# ════════════════════════════════════════════════════
#  UPGRADE PANEL
# ════════════════════════════════════════════════════
<UpgradePanel>:
    size_hint: 1, 1

    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.72
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: "vertical"
        spacing: 0
        size_hint: None, None
        size: min(dp(600), Window.width * 0.95), min(dp(340), Window.height * 0.55)
        pos_hint: {"center_x": 0.5, "center_y": 0.5}

        canvas.before:
            Color:
                rgba: 0.11, 0.11, 0.12, 0.98
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(18)]
            Color:
                rgba: 1, 1, 1, 0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, dp(18)
                width: dp(1.2)
            Color:
                rgba: 1, 1, 1, 0.025
            RoundedRectangle:
                pos: self.x + dp(2), self.top - dp(50)
                size: self.width - dp(4), dp(48)
                radius: [dp(18), dp(18), 0, 0]

        # HEADER
        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: dp(80)
            spacing: dp(4)
            padding: [0, dp(18), 0, 0]

            Label:
                text: "LEVEL UP"
                font_size: sp(28)
                bold: True
                color: 0.96, 0.96, 0.96, 1
                halign: "center"
                valign: "middle"
                text_size: self.size

            Label:
                text: "Choose an Upgrade"
                font_size: sp(11)
                color: 1, 1, 1, 0.40
                halign: "center"
                valign: "middle"
                text_size: self.size

        Widget:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.05
                Rectangle:
                    pos: self.x + dp(28), self.y
                    size: self.width - dp(56), dp(1)

        # UPGRADE BOX
        BoxLayout:
            id: upgrade_box
            orientation: "horizontal"
            spacing: dp(16)
            padding: [dp(18), dp(18), dp(18), dp(18)]
