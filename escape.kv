#:import Window kivy.core.window.Window
<MainMenu>:

    # ── BACKGROUND IMAGE ──
    Image:
        source: 'gameAsset\game_menu\menu.png'
        allow_stretch: True
        keep_ratio: False
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

    # ── DARK OVERLAY ──
    Widget:
        size_hint: 1, 1
        canvas:
            Color:
                rgba: 0, 0, 0, 0.60
            Rectangle:
                pos: self.pos
                size: self.size

    # ── LEFT PANEL ──
    BoxLayout:
        orientation: 'vertical'
        size_hint: None, 1
        width: 340
        pos_hint: {'x': 0, 'y': 0}
        spacing: 8
        padding: [28, 36, 28, 28]

        canvas.before:
            Color:
                rgba: 0.04, 0.04, 0.08, 0.93
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 0.91, 0.75, 0.29, 0.4
            Rectangle:
                pos: self.right - 2, self.y
                size: 2, self.height
            Color:
                rgba: 0.91, 0.75, 0.29, 1
            
        # ── TITLE ──
        

        Label:
            text: 'LAST TEEN STANDING'
            font_size: 28
            bold: True
            color: 0.91, 0.9, 0.96, 1
            size_hint_y: None
            height: 60
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        Label:
            text: 'MAIN MENU'
            font_size: 10
            color: 0.42, 0.39, 0.54, 1
            size_hint_y: None
            height: 20
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        # ── DIVIDER ──
        Widget:
            size_hint_y: None
            height: 1
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.07
                Rectangle:
                    pos: self.pos
                    size: self.size

        Widget:
            size_hint_y: None
            height: 6

        # ── STATS ROW ──
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 64
            spacing: 8

            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.03
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]
                Label:
                    text: 'BEST SCORE'
                    font_size: 9
                    bold: True
                    color: 0.5, 0.45, 0.65, 1
                    size_hint_y: None
                    height: 18
                    halign: 'center'
                    text_size: self.size
                Label:
                    id: best_score_label
                    text: '0'
                    font_size: 18
                    bold: True
                    color: 0.91, 0.75, 0.29, 1
                    halign: 'center'
                    text_size: self.size

            BoxLayout:
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.03
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]
                Label:
                    text: 'BEST WAVE'
                    font_size: 9
                    bold: True
                    color: 0.5, 0.45, 0.65, 1
                    size_hint_y: None
                    height: 18
                    halign: 'center'
                    text_size: self.size
                Label:
                    id: best_wave_label
                    text: '0'
                    font_size: 18
                    bold: True
                    color: 0.85, 0.8, 1, 1
                    halign: 'center'
                    text_size: self.size

        Widget:
            size_hint_y: None
            height: 14

        # ── NEW GAME BUTTON (gold) ──
        Button:
            text: 'NEW GAME'
            size_hint_y: None
            height: 54
            font_size: 14
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.15, 0.12, 0.05, 1
            on_release: 
                root.start_new_game()
                app.play_click()
            canvas.before:
                Color:
                    rgba: 0.91, 0.75, 0.29, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8]
                Color:
                    rgba: 1, 1, 1, 0.12
                RoundedRectangle:
                    pos: self.x + 4, self.top - 10
                    size: self.width - 8, 8
                    radius: [6]

        # ── CONTINUE BUTTON ──
        Button:
            id: continue_btn
            text: 'CONTINUE FROM WAVE'
            size_hint_y: None
            height: 54
            font_size: 13
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.88, 0.86, 0.94, 1
            on_release: 
                root.continue_game()
                app.play_click()
            canvas.before:
                Color:
                    rgba: 0.12, 0.13, 0.18, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8]
                Color:
                    rgba: 1, 1, 1, 0.06
                Line:
                    rounded_rectangle: self.x, self.y, self.width, self.height, 8
                    width: 1
                Color:
                    rgba: 0.91, 0.75, 0.29, 0.7
                

        # ── QUIT BUTTON ──
        Button:
            text: 'QUIT'
            size_hint_y: None
            height: 54
            font_size: 14
            bold: True
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.90, 0.38, 0.38, 1
            on_release: 
                app.play_click()
                app.stop()
                
            canvas.before:
                Color:
                    rgba: 0.18, 0.07, 0.07, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8]
                Color:
                    rgba: 0.80, 0.22, 0.22, 0.25
                Line:
                    rounded_rectangle: self.x, self.y, self.width, self.height, 8
                    width: 1
                Color:
                    rgba: 0.85, 0.25, 0.25, 0.8
                

        Widget:

        Label:
            text: 'v1.0.0'
            font_size: 9
            color: 0.25, 0.22, 0.32, 1
            size_hint_y: None
            height: 18
            halign: 'left'
            valign: 'middle'
            text_size: self.size

<Game>:

<Ground>:
    size_hint: None, None
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            source: root.source
            pos: self.pos
            size: self.size

<Obstacle>:
    size_hint: None, None
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            source: root.source
            pos: self.pos
            size: self.size

<Player>:
    size_hint: None, None
    size: 100, 100
    canvas:
        Rectangle:
            texture: root.texture
            pos: self.pos
            size: self.size

<Enemy>:
    size_hint: None, None
    size: 30, 30
    canvas:
        Color:
            rgba: root.color
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

<Effect>:
    size_hint: None, None
    size: 100, 100
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

<DamageNumber@Label>:
    size_hint: None, None
    font_size: 20
    bold: True
    color: 1, 0.24, 0.24, 1

<Attack>:
    size_hint: None, None
    size: 15, 15
    canvas:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            texture: root.texture
            size: self.size
            pos: self.pos

# ── JOYSTICK (movement) ──────────────────────────────
<Joystick>:
    size_hint: None, None
    size: 150, 150
    canvas:
        Color:
            rgba: 0, 0, 0, 0.45
        Ellipse:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0, 1, 0.8, 0.30
        Line:
            ellipse: self.x, self.y, self.width, self.height
            width: 2
        Color:
            rgba: 0, 1, 0.8, 0.10
        Line:
            points: self.center_x - 58, self.center_y, self.center_x + 58, self.center_y
            width: 1
        Color:
            rgba: 0, 1, 0.8, 0.10
        Line:
            points: self.center_x, self.center_y - 58, self.center_x, self.center_y + 58
            width: 1
        Color:
            rgba: 0, 1, 0.8, 0.15
        Ellipse:
            pos: self.center_x - 32, self.center_y - 32
            size: 64, 64
        Color:
            rgba: 0.04, 0.10, 0.14, 0.95
        Ellipse:
            pos: root.knob_x - 26, root.knob_y - 26
            size: 52, 52
        Color:
            rgba: 0, 1, 0.8, 0.90
        Line:
            ellipse: root.knob_x - 26, root.knob_y - 26, 52, 52
            width: 1.8

# ── ATTACK JOYSTICK (fire) ───────────────────────────
<AttackJoystick>:
    size_hint: None, None
    size: 150, 150
    canvas:
        Color:
            rgba: 0, 0, 0, 0.45
        Ellipse:
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 0.24, 0.24, 0.35
        Line:
            ellipse: self.x, self.y, self.width, self.height
            width: 2
        Color:
            rgba: 1, 0.24, 0.24, 0.10
        Line:
            points: self.center_x - 58, self.center_y, self.center_x + 58, self.center_y
            width: 1
        Color:
            rgba: 1, 0.24, 0.24, 0.10
        Line:
            points: self.center_x, self.center_y - 58, self.center_x, self.center_y + 58
            width: 1
        Color:
            rgba: 1, 0.24, 0.24, 0.18
        Ellipse:
            pos: self.center_x - 32, self.center_y - 32
            size: 64, 64
        Color:
            rgba: 0.14, 0.04, 0.04, 0.95
        Ellipse:
            pos: root.knob_x - 26, root.knob_y - 26
            size: 52, 52
        Color:
            rgba: 1, 0.24, 0.24, 0.90
        Line:
            ellipse: root.knob_x - 26, root.knob_y - 26, 52, 52
            width: 1.8

<HealthBar>:
    size_hint: None, None
    size: 90, 10
    canvas:
        Color:
            rgba: 0.08, 0.08, 0.10, 0.92
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]
        Color:
            rgba: 0.3, 0.05, 0.05, 0.8
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, 5
            width: 1
        Color:
            rgba: (1, 0.18, 0.18, 1) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.width * min(1, self.health / self.max_health), self.height
            radius: [5]
            
<PlayerHealthBar>:
    size_hint: None, None
    size: 260, 80

    canvas.before:
        # Card background
        Color:
            rgba: 0.04, 0.05, 0.06, 0.94
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [14]
        Color:
            rgba: 1, 1, 1, 0.07
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, 14
            width: 1

        # Heart icon box  (top-left area)
        Color:
            rgba: 0.9, 0.21, 0.21, 0.18
        RoundedRectangle:
            pos: self.x + 12, self.y + 44
            size: 28, 28
            radius: [8]
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            source: "gameAsset/Characters/player_icon.png"
            pos: self.x + 16, self.y + 48
            size: 20, 20

        Color:
            rgba: 0.9, 0.21, 0.21, 0.38
        Line:
            rounded_rectangle: self.x + 12, self.y + 44, 28, 28, 8
            width: 1


        # HP bar track
        Color:
            rgba: 1, 1, 1, 0.07
        RoundedRectangle:
            pos: self.x + 12, self.y + 30
            size: self.width - 24, 8
            radius: [4]

        # HP bar fill
        Color:
            rgba: (0.9, 0.21, 0.21, 1) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x + 12, self.y + 30
            size: (0, 0) if self.health <= 0 else ((self.width - 24) * max(0, min(1, self.health / self.max_health)), 8)
            radius: [4]

        # Shimmer highlight on fill
        Color:
            rgba: (1, 1, 1, 0.18) if self.health > 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x + 18, self.y + 34
            size:(0, 0) if self.health <= 0 else (max(0, (self.width - 36) * max(0, min(1, self.health / self.max_health))), 2)       
            radius: [2]

        # Divider line
        Color:
            rgba: 1, 1, 1, 0.05
        Rectangle:
            pos: self.x + 12, self.y + 22
            size: self.width - 24, 1

    # "PLAYER" label
    Label:
        text: "TEEN"
        font_size: 11
        bold: True
        color: 1, 1, 1, 0.55
        pos: root.x + 48, root.y + 44
        size: 100, 28
        halign: "left"
        valign: "middle"
        text_size: self.size

    # HP number
    Label:
        text: f"{max(0, int(root.health))} / {int(root.max_health)}"
        font_size: 13
        bold: True
        color: 1, 1, 1, 1
        pos: root.right - 80, root.y + 44
        size: 68, 28
        halign: "right"
        valign: "middle"
        text_size: self.size

    # Status effect text
    Label:
        id: status_label
        text: root.status_text
        font_size: 14
        bold: True
        color: root.status_color
        pos: root.x + 24, root.y + 4
        size: root.width - 36, 20
        halign: "left"
        valign: "middle"
        text_size: self.size
<PowerUp>:
    size_hint: None, None
    size: 28, 28
    canvas:
        Color:
            rgba: root.color[0], root.color[1], root.color[2], 0.28
        Ellipse:
            pos: self.x - 5, self.y - 5
            size: self.width + 10, self.height + 10
        Color:
            rgba: root.color
        Ellipse:
            texture: root.texture
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 1, 1, 0.20
        Ellipse:
            pos: self.center_x - 8, self.center_y - 2
            size: 10, 6
    Label:
        text: root.symbol
        center: root.center
        font_size: 15
        bold: True
        color: 0, 0, 0, 0.9

<Gun>:
    size_hint: None, None
    size: 34, 12
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas:
        Color:
            rgba: 0.12, 0.15, 0.20, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [3]
        Color:
            rgba: 0.50, 0.62, 0.72, 1
        RoundedRectangle:
            pos: self.center_x, self.center_y - 2
            size: 14, 4
            radius: [2]
        Color:
            rgba: 0, 1, 0.8, 0.85
        Rectangle:
            pos: self.right - 3, self.center_y - 2
            size: 3, 4
    canvas.after:
        PopMatrix



<GameUI>:
    ammo_ratio: 1
    size_hint: 1, 1

    # ─────────────────────────────────────────────
    # PAUSE MENU
    # ─────────────────────────────────────────────
    FloatLayout:
        id: pause_menu
        opacity: 0
        disabled: True

        # ── BACKGROUND IMAGE ──
        Image:
            source: 'gameAsset\game_menu\menu.png'
            allow_stretch: True
            keep_ratio: False
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}

        # ── DARK OVERLAY (as a Widget child, not canvas.before on FloatLayout) ──
        Widget:
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            canvas:
                Color:
                    rgba: 0, 0, 0, 0.55
                Rectangle:
                    pos: self.pos
                    size: self.size

        # ── LEFT PANEL ──
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, 1
            width: 320
            pos_hint: {'x': 0, 'y': 0}
            spacing: 6
            padding: [28, 32, 28, 24]

            canvas.before:
                Color:
                    rgba: 0.04, 0.04, 0.08, 0.93
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.91, 0.75, 0.29, 0.4
                Rectangle:
                    pos: self.right - 2, self.y
                    size: 2, self.height
                Color:
                    rgba: 0.91, 0.75, 0.29, 1
                

            Label:
                text: 'LAST TEEN STANDING'
                font_size: 11
                bold: True
                color: 0.91, 0.75, 0.29, 1
                size_hint_y: None
                height: 20
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            Label:
                text: 'PAUSED'
                font_size: 26
                bold: True
                color: 0.91, 0.9, 0.96, 1
                size_hint_y: None
                height: 38
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            

            Widget:
                size_hint_y: None
                height: 1
                canvas:
                    Color:
                        rgba: 1, 1, 1, 0.07
                    Rectangle:
                        pos: self.pos
                        size: self.size

            Widget:
                size_hint_y: None
                height: 8

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: 64
                spacing: 8

                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.03
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]
                    Label:
                        text: 'WAVE'
                        font_size: 9
                        bold: True
                        color: 0.5, 0.45, 0.65, 1
                        size_hint_y: None
                        height: 18
                        halign: 'center'
                        text_size: self.size
                    Label:
                        id: stat_wave
                        text: '1'
                        font_size: 20
                        bold: True
                        color: 0.85, 0.8, 1, 1
                        halign: 'center'
                        text_size: self.size

                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.03
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]
                    Label:
                        text: 'SCORE'
                        font_size: 9
                        bold: True
                        color: 0.5, 0.45, 0.65, 1
                        size_hint_y: None
                        height: 18
                        halign: 'center'
                        text_size: self.size
                    Label:
                        id: stat_score
                        text: '0'
                        font_size: 20
                        bold: True
                        color: 0.85, 0.8, 1, 1
                        halign: 'center'
                        text_size: self.size

            Widget:
                size_hint_y: None
                height: 16

            Button:
                text: 'RESUME'
                size_hint_y: None
                height: 54
                font_size: 14
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.15, 0.12, 0.05, 1
                on_release: 
                    root.parent.resume()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.91, 0.75, 0.29, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [8]
                    Color:
                        rgba: 1, 1, 1, 0.12
                    RoundedRectangle:
                        pos: self.x + 4, self.top - 10
                        size: self.width - 8, 8
                        radius: [6]

            Button:
                text: 'RESTART'
                size_hint_y: None
                height: 54
                font_size: 14
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.88, 0.86, 0.94, 1
                on_release: 
                    root.parent.restart()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.12, 0.13, 0.18, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [8]
                    Color:
                        rgba: 1, 1, 1, 0.06
                    Line:
                        rounded_rectangle: self.x, self.y, self.width, self.height, 8
                        width: 1
                    Color:
                        rgba: 0.91, 0.75, 0.29, 0.7
                    
            Button:
                text: 'QUIT TO MENU'
                size_hint_y: None
                height: 54
                font_size: 14
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.90, 0.38, 0.38, 1
                on_release: 
                    root.parent.quit_to_menu()
                    root.parent.play_click()
                canvas.before:
                    Color:
                        rgba: 0.18, 0.07, 0.07, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [8]
                    Color:
                        rgba: 0.80, 0.22, 0.22, 0.25
                    Line:
                        rounded_rectangle: self.x, self.y, self.width, self.height, 8
                        width: 1
                    Color:
                        rgba: 0.85, 0.25, 0.25, 0.8
                    

            Widget:

            Label:
                text: 'v1.0.0  ·  WAVE IN PROGRESS'
                font_size: 9
                color: 0.25, 0.22, 0.32, 1
                size_hint_y: None
                height: 18
                halign: 'left'
                valign: 'middle'
                text_size: self.size
    # ─────────────────────────────────────────────
    # PAUSE BUTTON
    # ─────────────────────────────────────────────
    Button:
        id: pause_button
        text: "II"

        size_hint: None, None
        size: 50, 50

        pos_hint: {"right": 0.985, "top": 0.985}

        font_size: 16
        bold: True

        background_normal: ""
        background_color: 0,0,0,0

        color: 1,1,1,0.92

        on_release: 
            root.parent.pause()
            root.parent.play_click()

        canvas.before:
            Color:
                rgba: 0.12,0.13,0.16,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, 12
                width: 1

    # ─────────────────────────────────────────────
    # WEAPON BUTTON
    # ─────────────────────────────────────────────
    Button:
        id: weapon_button 
        text: "W"

        size_hint: None, None
        size: 50, 50

        pos_hint: {"right": 0.985, "top": 0.89}

        font_size: 18
        bold: True

        background_normal: ""
        background_color: 0,0,0,0

        color: 0.92,0.82,0.58,1

        on_release:
            root.parent.weapon_menu.open_menu(list(root.parent.player.guns.keys()), self.center_x, self.center_y)
            root.parent.play_click()
        canvas.before:
            Color:
                rgba: 0.14,0.12,0.09,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

            Color:
                rgba: 0.92,0.82,0.58,0.15
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, 12
                width: 1

    # ─────────────────────────────────────────────
    # GUN BAR
    # ─────────────────────────────────────────────
    GunBar:
        id: gun_ui

        orientation: "horizontal"

        size_hint: None, None
        size: 320, 64

        spacing: 12
        padding: [14,10]

        pos_hint: {"center_x": 0.5, "y": 0.016}

        on_release: root.parent.player.gun.startReload()

        canvas.before:
            Color:
                rgba: 0.10,0.11,0.13,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [14]

            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, 14
                width: 1

        # ── ICON BOX ──
        
        BoxLayout:
            size_hint_x: None
            width: 40
            padding: [4, 4, 4, 4]

            canvas.before:
                Color:
                    rgba: 1,1,1,0.04
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8]

            Image:
                id: gun_icon

                source: "gameAsset/gun/ak.png"

                size_hint: 1, 1
                
                

        BoxLayout:
            orientation: "vertical"
            size_hint_x: None
            width: 110

            Label:
                id: gun_text
                text: "ASSAULT"
                font_size: 13
                bold: True
                color: 1,1,1,0.96
                halign: "left"
                valign: "middle"
                text_size: self.size

            Label:
                id: ammo_text
                text: "30 / 30"
                font_size: 11
                bold: True
                color: 0.82,0.74,0.55,0.85
                halign: "left"
                valign: "middle"
                text_size: self.size

        BoxLayout:
            orientation: "vertical"
            spacing: 5

            Widget:
                size_hint_y: None
                height: 8

                canvas:
                    Color:
                        rgba: 0.18,0.18,0.20,1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]

                    Color:
                        rgba: 0.88,0.77,0.50,1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.width * root.ammo_ratio, self.height
                        radius: [4]

            Label:
                text: "TAP TO RELOAD"
                font_size: 9
                bold: True
                color: 1,1,1,0.35
                halign: "center"
                valign: "middle"
                text_size: self.size

    # ─────────────────────────────────────────────
    # TOP HUD
    # ─────────────────────────────────────────────
    BoxLayout:
        id: top_hud

        orientation: "horizontal"

        size_hint: None, None
        size: 320, 58

        spacing: 8
        padding: [10,8]

        pos_hint: {"center_x": 0.5, "top": 0.985}

        canvas.before:
            Color:
                rgba: 0.10,0.11,0.13,0.96
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

            Color:
                rgba: 1,1,1,0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, 12
                width: 1

        # Wave
        BoxLayout:
            orientation: "vertical"

            canvas.before:
                Color:
                    rgba: 1,1,1,0.025
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8]

            Label:
                text: "WAVE"

                font_size: 9
                bold: True

                color: 0.82,0.74,0.55,0.75

                size_hint_y: None
                height: 14

            Label:
                id: wave_label
                text: "1"

                font_size: 21
                bold: True

                color: 0.96,0.96,0.96,1

        Widget:
            size_hint_x: None
            width: 1

            canvas:
                Color:
                    rgba: 1,1,1,0.04
                Rectangle:
                    pos: self.center_x, self.y + 10
                    size: 1, self.height - 20

        # Score
        BoxLayout:
            orientation: "vertical"

            canvas.before:
                Color:
                    rgba: 1,1,1,0.025
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8]

            Label:
                text: "SCORE"

                font_size: 9
                bold: True

                color: 0.82,0.74,0.55,0.75

                size_hint_y: None
                height: 14

            Label:
                id: score_label
                text: "0"

                font_size: 21
                bold: True

                color: 0.96,0.96,0.96,1


<GunBar@ButtonBehavior+BoxLayout>:



# ════════════════════════════════════════════════════
#  UPGRADE PANEL
# ════════════════════════════════════════════════════
<UpgradePanel>:
    size_hint: 1, 1

    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.72
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: "vertical"
        spacing: 0
        size_hint: None, None
        size: 600, 340
        pos_hint: {"center_x": 0.5, "center_y": 0.5}

        canvas.before:

            # Main background
            Color:
                rgba: 0.11, 0.11, 0.12, 0.98
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [18]

            # Soft border
            Color:
                rgba: 1, 1, 1, 0.05
            Line:
                rounded_rectangle: self.x, self.y, self.width, self.height, 18
                width: 1.2

            # Top subtle highlight
            Color:
                rgba: 1, 1, 1, 0.025
            RoundedRectangle:
                pos: self.x + 2, self.top - 50
                size: self.width - 4, 48
                radius: [18,18,0,0]

        # =====================================================
        # HEADER
        # =====================================================
        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: 80
            spacing: 4
            padding: [0, 18, 0, 0]

            Label:
                text: "LEVEL UP"
                font_size: 28
                bold: True
                color: 0.96, 0.96, 0.96, 1
                halign: "center"
                valign: "middle"
                text_size: self.size

            Label:
                text: "Choose an Upgrade"
                font_size: 11
                color: 1, 1, 1, 0.40
                halign: "center"
                valign: "middle"
                text_size: self.size

        # Divider
        Widget:
            size_hint_y: None
            height: 1

            canvas:
                Color:
                    rgba: 1, 1, 1, 0.05
                Rectangle:
                    pos: self.x + 28, self.y
                    size: self.width - 56, 1

        # =====================================================
        # UPGRADE BOX
        # =====================================================
        BoxLayout:
            id: upgrade_box
            orientation: "horizontal"
            spacing: 16
            padding: [18, 18, 18, 18]